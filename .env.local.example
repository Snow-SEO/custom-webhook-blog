NODE_ENV=development

# Webhook Receiver Environment Configuration
# Copy these values into .env

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database

# Shared SnowSEO webhook secret used by both this app and the SnowSEO webhook settings
SNOWSEO_WEBHOOK_SECRET=your-secure-webhook-secret

# Enable debug logging
WEBHOOK_DEBUG=false

# Public base URL of this blog — used to return cmsUrl in webhook responses
# e.g. "https://your-blog.vercel.app" — no trailing slash
# If not set, cmsUrl will be relative (not recommended for production)
WEBHOOK_BLOG_BASE_URL=https://your-blog.vercel.app